#!/bin/bash

# SessionStart Classification Hook
# Reads the installed router SKILL.md and injects its content as additionalContext.
# The router SKILL.md is the single source of truth for ambient classification rules.
# Zero duplication — content lives in one place, injected once per session.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/json-parse"
if [ "$_JSON_AVAILABLE" = "false" ]; then exit 0; fi

INPUT=$(cat)

CWD=$(echo "$INPUT" | json_field "cwd" "")
if [ -z "$CWD" ]; then exit 0; fi

ROUTER_SKILL="$HOME/.claude/skills/devflow:router/SKILL.md"
if [ ! -f "$ROUTER_SKILL" ]; then exit 0; fi

# Strip YAML frontmatter (everything between first two --- lines)
CONTEXT=$(awk '/^---$/{n++; next} n>=2' "$ROUTER_SKILL")

json_session_output "$CONTEXT"
