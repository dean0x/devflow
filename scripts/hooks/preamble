#!/bin/bash

# Devflow Preamble: UserPromptSubmit Hook
# Three behaviors (git repos only — silent outside a git tree):
#   1. Plan-handoff fast-path: if prompt begins `Implement the following plan:` (Claude Code's
#      native plan-mode handoff), inject a directive to invoke devflow:implement immediately.
#      NOTE: the literal prefix is duplicated in orchestrator-charter.md (fallback bullet)
#      and scripts/hooks/preamble — update both together if Claude Code changes the handoff format.
#   2. Slash skip: no reminder for slash commands (/...).
#   3. Orchestrator reminder (2 lines): all other prompts get a delegation reminder.

# Safe no-op fallback: must exist before hook-bootstrap is sourced.
dbg() { :; }

# set -e intentionally omitted: guard clauses ensure fail-open exit 0 on all paths.

# Re-entrancy guard — before hook-bootstrap to minimize background session overhead.
# The memory worker's own claude -p session fires UserPromptSubmit; without this guard
# the nested background session would receive the orchestrator reminder (or, on a
# matching prompt, a plan-handoff directive) it must never act on. Mirrors the sibling
# capture-prompt UserPromptSubmit hook and session-start-orchestrator.
if [ "${DEVFLOW_BG_UPDATER:-}" = "1" ]; then dbg "EXIT: bg_updater"; exit 0; fi

# JSON parsing (jq with node fallback) — silently no-op if neither available
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$SCRIPT_DIR/hook-bootstrap" "preamble"

source "$SCRIPT_DIR/json-parse" || { echo "preamble: failed to source json-parse" >&2; exit 1; }
if [ "$_JSON_AVAILABLE" = "false" ]; then exit 0; fi

INPUT=$(cat)

FIELDS=$(printf '%s' "$INPUT" | json_extract_cwd_prompt)
CWD="${FIELDS%%$'\001'*}"
PROMPT="${FIELDS#*$'\001'}"

dbg "PROMPT_LENGTH=${#PROMPT}"

if [ -z "$CWD" ] || [ ! -d "$CWD" ]; then
  dbg "EXIT: bad CWD"
  exit 0
fi

devflow_debug_set_cwd "$CWD"
dbg "CWD=$CWD"

# --- Git-repo gate (pure bash, bounded walk) ---
source "$SCRIPT_DIR/git-marker" || true
if ! df_has_git_marker "$CWD" 2>/dev/null; then dbg "EXIT: not a git repo"; exit 0; fi

# --- Prompt dispatch (pure bash 3.2; no subprocess in this block) ---
# The plan-handoff prefix is a Claude Code protocol marker (native "execute plan
# in new session" handoff), matched literally — plumbing, not semantic detection.
# Duplicated in orchestrator-charter.md (fallback bullet); update both together.
# Known bound: prefix must appear within the first 256 bytes after whitespace
# strip (native handoffs have zero leading whitespace).
HEAD="${PROMPT:0:256}"
HEAD="${HEAD#"${HEAD%%[![:space:]]*}"}"   # strip leading whitespace/newlines

if [ -z "$HEAD" ]; then
  dbg "EXIT: empty prompt"
elif [[ "$HEAD" == "Implement the following plan:"* ]]; then
  dbg "PLAN_HANDOFF detected — injecting devflow:implement directive"
  json_prompt_output "The user's prompt is a plan handoff (it begins with \`Implement the following plan:\`). In one short sentence, tell the user you're invoking \`devflow:implement\`. Then immediately invoke it with the Skill tool, passing the full plan (everything after the handoff prefix) as the skill input so it can be executed. Do not pause to ask whether to proceed."
elif [[ "$HEAD" == "/"* ]]; then
  dbg "EXIT: slash command — no reminder"
else
  # Model-tier taxonomy (haiku=mechanical, sonnet=defined execution, opus=analysis/design/research)
  # is cross-referenced with the full routing table in orchestrator-charter.md.
  # Update both together if routing changes.
  dbg "ORCHESTRATOR_REMINDER injected"
  json_prompt_output "Orchestrator reminder: coordinate, don't produce — delegate edits, builds, multi-file reads, and debug loops via the Agent tool (haiku=mechanical, sonnet=defined execution, opus=analysis/design/research) or the matching devflow workflow skill.
Keep only judgment work mainline: conversation, decisions, routing, synthesis of agent reports."
fi

dbg "=== HOOK COMPLETE ==="
