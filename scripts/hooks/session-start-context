#!/bin/bash

# SessionStart Hook: Cross-Feature Context Injection
# Always-on hook that injects decisions TL;DR and learned behaviors as additionalContext.
# Sections are independently gated by feature sentinels — this hook itself is never disabled.
#
# Section 1.5: Decisions TL;DR (skipped if .devflow/decisions/.disabled)
# Section 1.75: Learned behaviors + new artifact notifications (skipped if .devflow/memory/.learning-disabled)
# Section 2: Sidecar pending-work (emits directive when pending tasks detected)

# Safe no-op fallback: must exist before hook-bootstrap is sourced.
dbg() { :; }

# set -e intentionally omitted: sections 1.5, 1.75, and 2 are independent —
# a failure in one must not prevent the others from running.

# JSON parsing (jq with node fallback) — silently no-op if neither available
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$SCRIPT_DIR/hook-bootstrap" "session-start-context"

source "$SCRIPT_DIR/json-parse" || { echo "session-start-context: failed to source json-parse" >&2; exit 1; }
if [ "$_JSON_AVAILABLE" = "false" ]; then exit 0; fi

INPUT=$(cat)

CWD=$(printf '%s' "$INPUT" | json_field "cwd" "")
if [ -z "$CWD" ] || [ ! -d "$CWD" ]; then
  dbg "EXIT: bad CWD"
  exit 0
fi

devflow_debug_set_cwd "$CWD"
dbg "CWD=$CWD"

CONTEXT=""

DEVFLOW_DIR="$CWD/.devflow"
MEMORY_DIR="$DEVFLOW_DIR/memory"
SIDECAR_DIR="$DEVFLOW_DIR/sidecar"
LEARNING_DIR="$DEVFLOW_DIR/learning"
DECISIONS_CONTENT_DIR="$DEVFLOW_DIR/decisions"

# Normal logging
source "$SCRIPT_DIR/hook-log-init" "session-start-context"

# Read sidecar config for feature state (primary source of truth)
_SIDECAR_CONFIG="$SIDECAR_DIR/config.json"
_LEARNING_SIDECAR="true"
if [ -f "$_SIDECAR_CONFIG" ]; then
  _LEARNING_SIDECAR=$(json_field_file "$_SIDECAR_CONFIG" "learning" "true")
fi

dbg "LEARNING_SIDECAR=$_LEARNING_SIDECAR"

# --- Section 1.5: Project Decisions TL;DR ---
# Skipped if decisions feature is disabled via sentinel.
if [ ! -f "$DECISIONS_CONTENT_DIR/.disabled" ]; then
  DECISIONS_DIR="$DECISIONS_CONTENT_DIR"
  # Heal older installs that have .devflow/ but not .devflow/decisions/
  if [ -d "$DEVFLOW_DIR" ] && [ ! -d "$DECISIONS_DIR" ]; then
    mkdir -p "$DECISIONS_DIR" 2>/dev/null || true
  fi
  if [ -d "$DECISIONS_DIR" ]; then
    DECISIONS_TLDR=""
    for kf in "$DECISIONS_DIR"/decisions.md "$DECISIONS_DIR"/pitfalls.md; do
      if [ -f "$kf" ]; then
        TLDR_LINE=$(sed -n '1s/<!-- TL;DR: \(.*\) -->/\1/p' "$kf")
        if [ -n "$TLDR_LINE" ]; then
          DECISIONS_TLDR="${DECISIONS_TLDR}${TLDR_LINE}\n"
        fi
      fi
    done
    if [ -n "$DECISIONS_TLDR" ]; then
      dbg "Decisions TL;DR found"
      DECISIONS_SECTION="--- PROJECT DECISIONS (TL;DR) ---
$(printf '%b' "$DECISIONS_TLDR")"
      if [ -n "$CONTEXT" ]; then
        CONTEXT="${CONTEXT}

${DECISIONS_SECTION}"
      else
        CONTEXT="$DECISIONS_SECTION"
      fi
    fi
  fi
fi

# --- Section 1.75: Learned Behaviors ---
# Skipped if learning feature is disabled via sentinel or sidecar config.
#
# _build_learned_section LEARNING_LOG NOTIFIED_MARKER
#   Prints the LEARNED BEHAVIORS block to stdout, or nothing if no artifacts exist.
#   Side-effect: updates NOTIFIED_MARKER when new artifacts are present.
_build_learned_section() {
  local log_file="$1" notified_marker="$2"

  # Single-pass extraction of created artifacts (commands + skills)
  local learned_json
  learned_json=$(json_learning_created "$log_file")

  local learned_commands="" learned_skills=""
  if [ -n "$learned_json" ]; then
    if [ "$_HAS_JQ" = "true" ]; then
      learned_commands=$(echo "$learned_json" | jq -r '.commands | map("/self-learning/\(.name) (\(.conf))") | join(", ")' 2>/dev/null)
      learned_skills=$(echo "$learned_json" | jq -r '.skills | map("\(.name) (\(.conf))") | join(", ")' 2>/dev/null)
    else
      # Node fallback: parse the JSON and format
      learned_commands=$(echo "$learned_json" | node -e "
        const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
        console.log(d.commands.map(c=>\"/self-learning/\"+c.name+\" (\"+c.conf+\")\").join(', '));
      " 2>/dev/null)
      learned_skills=$(echo "$learned_json" | node -e "
        const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
        console.log(d.skills.map(s=>s.name+\" (\"+s.conf+\")\").join(', '));
      " 2>/dev/null)
    fi
  fi

  if [ "${DEVFLOW_HOOK_DEBUG:-}" = "1" ]; then dbg "Learned artifacts: commands='$learned_commands' skills='$learned_skills'"; fi
  [ -z "$learned_commands" ] && [ -z "$learned_skills" ] && return 0

  local section="--- LEARNED BEHAVIORS ---"
  [ -n "$learned_commands" ] && section="${section}
Commands: $learned_commands"
  [ -n "$learned_skills" ] && section="${section}
Skills: $learned_skills"
  section="${section}
Edit or delete: .claude/commands/self-learning/ and .claude/skills/"

  # Check for new artifacts since last notification (single jq -s pass)
  local last_notified=0
  [ -f "$notified_marker" ] && last_notified=$(cat "$notified_marker" 2>/dev/null || echo "0")

  local new_artifacts
  new_artifacts=$(json_learning_new "$log_file" "$last_notified")

  if [ -n "$new_artifacts" ]; then
    section="${section}

--- NEW LEARNED BEHAVIORS ---
${new_artifacts}
TIP: Type the command name to use it. Rename to shorter path for quicker access.
Run \`devflow learn --list\` to see all."
    # Only update notified marker when new artifacts exist
    date +%s > "$notified_marker" 2>/dev/null || true
  fi

  printf '%s' "$section"
}

if [ "$_LEARNING_SIDECAR" = "true" ] && [ ! -f "$MEMORY_DIR/.learning-disabled" ]; then
  LEARNING_LOG="$LEARNING_DIR/learning-log.jsonl"
  NOTIFIED_MARKER="$LEARNING_DIR/.learning-notified-at"

  if [ -f "$LEARNING_LOG" ]; then
    LEARNED_SECTION=$(_build_learned_section "$LEARNING_LOG" "$NOTIFIED_MARKER")
    if [ -n "$LEARNED_SECTION" ]; then
      if [ -n "$CONTEXT" ]; then
        CONTEXT="${CONTEXT}

${LEARNED_SECTION}"
      else
        CONTEXT="$LEARNED_SECTION"
      fi
    fi
  fi
fi

# --- Section 2: Sidecar Pending-Work ---
# Detects pending sidecar tasks and emits a directive to spawn a background processor agent.
# Guards: processor-spawn throttle (120s window) prevents duplicate emissions on rapid
# SessionStart events (e.g., /clear or compact).
# Requires: sidecar-recover + sidecar-collect-tasks helpers (sourced inline below).
# No set -e: any failure must not affect prior sections.

# Source helpers — soft-fail if absent (e.g., on older installs before rebuild).
# All sourced helpers follow the no-set-e discipline and exit cleanly on failure.
_SC2_HELPERS_OK="false"
if [ -f "$SCRIPT_DIR/get-mtime" ] && [ -f "$SCRIPT_DIR/sidecar-recover" ] && [ -f "$SCRIPT_DIR/sidecar-collect-tasks" ]; then
  source "$SCRIPT_DIR/get-mtime" 2>/dev/null || true
  source "$SCRIPT_DIR/sidecar-lock" 2>/dev/null || true
  source "$SCRIPT_DIR/sidecar-recover" 2>/dev/null || true
  source "$SCRIPT_DIR/sidecar-collect-tasks" 2>/dev/null || true
  _SC2_HELPERS_OK="true"
fi

if [ "$_SC2_HELPERS_OK" = "true" ]; then
  # Determine feature enabled-state.
  # Primary: sidecar/config.json fields; secondary: runtime sentinels (defense-in-depth).
  _SC2_MEM_EN="true"
  _SC2_LEARN_EN="true"
  _SC2_DEC_EN="true"
  _SC2_KNOW_EN="true"

  _SC2_SIDECAR_CONFIG="$SIDECAR_DIR/config.json"
  if [ -f "$_SC2_SIDECAR_CONFIG" ]; then
    _SC2_MEM_EN=$(json_field_file   "$_SC2_SIDECAR_CONFIG" "memory"    "true")
    _SC2_LEARN_EN=$(json_field_file "$_SC2_SIDECAR_CONFIG" "learning"  "true")
    _SC2_DEC_EN=$(json_field_file   "$_SC2_SIDECAR_CONFIG" "decisions" "true")
    _SC2_KNOW_EN=$(json_field_file  "$_SC2_SIDECAR_CONFIG" "knowledge" "true")
  fi
  # Sentinel overrides
  [ -f "$MEMORY_DIR/.working-memory-disabled" ] && _SC2_MEM_EN="false"
  [ -f "$MEMORY_DIR/.learning-disabled" ]       && _SC2_LEARN_EN="false"
  [ -f "$DEVFLOW_DIR/decisions/.disabled" ]     && _SC2_DEC_EN="false"
  [ -f "$DEVFLOW_DIR/features/.disabled" ]      && _SC2_KNOW_EN="false"

  dbg "Section2: mem=$_SC2_MEM_EN learn=$_SC2_LEARN_EN dec=$_SC2_DEC_EN know=$_SC2_KNOW_EN"

  # Step 1: recover stale .processing markers so they become collectable in step 2
  if [ -d "$SIDECAR_DIR" ]; then
    sidecar_recover_stale "$SIDECAR_DIR" "$MEMORY_DIR" || true
  fi

  # Step 2: collect pending marker task types
  sidecar_collect_tasks "$SIDECAR_DIR" "$_SC2_MEM_EN" "$_SC2_LEARN_EN" "$_SC2_DEC_EN" "$_SC2_KNOW_EN" || true

  # Step 3: raw-queue bridge — union in memory task if .pending-turns.jsonl is non-empty
  # even when no memory sidecar marker exists (queue written but marker not yet written).
  if [ "$_SC2_MEM_EN" = "true" ] && [ -s "$MEMORY_DIR/.pending-turns.jsonl" ]; then
    case ",$_SIDECAR_TASKS," in
      *,memory,*) ;;  # already present — skip
      *)
        if [ -n "$_SIDECAR_TASKS" ]; then
          _SIDECAR_TASKS="memory,$_SIDECAR_TASKS"
        else
          _SIDECAR_TASKS="memory"
        fi
        dbg "Section2: added memory task via raw-queue bridge"
        ;;
    esac
  fi

  # Step 4: emit directive if tasks pending, subject to processor-spawn throttle
  if [ -n "$_SIDECAR_TASKS" ]; then
    _SC2_SPAWNED_AT_FILE="$SIDECAR_DIR/.processor-spawned-at"
    _SC2_THROTTLE=120
    _SC2_EMIT="true"
    _SC2_NOW=$(date +%s)

    if [ -f "$_SC2_SPAWNED_AT_FILE" ]; then
      _SC2_LAST_SPAWN=$(cat "$_SC2_SPAWNED_AT_FILE" 2>/dev/null | tr -dc '0-9' || true)
      _SC2_LAST_SPAWN="${_SC2_LAST_SPAWN:-0}"
      _SC2_SPAWN_AGE=$(( _SC2_NOW - _SC2_LAST_SPAWN ))
      if [ "$_SC2_SPAWN_AGE" -lt "$_SC2_THROTTLE" ]; then
        _SC2_EMIT="false"
        dbg "Section2: processor-spawn throttled (spawned ${_SC2_SPAWN_AGE}s ago)"
        log "Sidecar processor-spawn throttled (${_SC2_SPAWN_AGE}s < ${_SC2_THROTTLE}s): tasks=$_SIDECAR_TASKS"
      fi
    fi

    if [ "$_SC2_EMIT" = "true" ]; then
      # Write/refresh .processor-spawned-at atomically
      _SC2_SPAWN_TMP="$SIDECAR_DIR/.processor-spawned-at.tmp.$$"
      printf '%s' "$_SC2_NOW" > "$_SC2_SPAWN_TMP" 2>/dev/null && mv "$_SC2_SPAWN_TMP" "$_SC2_SPAWNED_AT_FILE" 2>/dev/null || rm -f "$_SC2_SPAWN_TMP" 2>/dev/null || true

      _SC2_DIRECTIVE="--- SIDECAR MAINTENANCE (pending from previous session) ---
Pending background maintenance: ${_SIDECAR_TASKS}.
FIRST ACTION, before responding to the user: load the devflow:sidecar skill and
spawn ONE background sidecar-processor agent (run_in_background: true).
Single non-blocking tool call. Do it now, then continue normally.
Do not summarize or ask about this — just spawn the processor."

      if [ -n "$CONTEXT" ]; then
        CONTEXT="${CONTEXT}

${_SC2_DIRECTIVE}"
      else
        CONTEXT="$_SC2_DIRECTIVE"
      fi
      dbg "Section2: emitted sidecar directive (tasks=$_SIDECAR_TASKS)"
      log "Sidecar pending-work directive emitted: tasks=$_SIDECAR_TASKS"
    fi
  else
    dbg "Section2: no pending sidecar tasks"
  fi
else
  dbg "Section2: helpers not available — skip"
fi

# --- Output ---

# Only output if we have something to inject
if [ -z "$CONTEXT" ]; then
  dbg "EXIT: no context to inject"
  exit 0
fi

dbg "OUTPUT_LENGTH=${#CONTEXT}"
log "Injecting context (${#CONTEXT} chars)"
dbg "=== HOOK COMPLETE ==="

# Output as additionalContext JSON envelope (Claude sees it as system context, not user-visible)
json_session_output "$CONTEXT"
