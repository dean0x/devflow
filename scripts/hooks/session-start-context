#!/bin/bash

# SessionStart Hook: Cross-Feature Context Injection
# Always-on hook that injects decisions TL;DR and learned behaviors as additionalContext.
# Sections are independently gated by feature sentinels — this hook itself is never disabled.
#
# Section 1.4: Learning manifest reconciliation (skipped if .devflow/memory/.learning-disabled)
# Section 1.5: Decisions TL;DR (skipped if .devflow/decisions/.disabled)
# Section 1.75: Learned behaviors + new artifact notifications (skipped if .devflow/memory/.learning-disabled)

# Safe no-op fallback: must exist before hook-bootstrap is sourced.
dbg() { :; }

# set -e intentionally omitted: sections 1.4, 1.5, and 1.75 are independent —
# a failure in one must not prevent the others from running.

# JSON parsing (jq with node fallback) — silently no-op if neither available
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$SCRIPT_DIR/hook-bootstrap" "session-start-context"

source "$SCRIPT_DIR/json-parse" || { echo "session-start-context: failed to source json-parse" >&2; exit 1; }
if [ "$_JSON_AVAILABLE" = "false" ]; then exit 0; fi

INPUT=$(cat)

CWD=$(printf '%s' "$INPUT" | json_field "cwd" "")
if [ -z "$CWD" ] || [ ! -d "$CWD" ]; then
  dbg "EXIT: bad CWD"
  exit 0
fi

devflow_debug_set_cwd "$CWD"
dbg "CWD=$CWD"

CONTEXT=""

DEVFLOW_DIR="$CWD/.devflow"
MEMORY_DIR="$DEVFLOW_DIR/memory"
SIDECAR_DIR="$DEVFLOW_DIR/sidecar"
LEARNING_DIR="$DEVFLOW_DIR/learning"
DECISIONS_CONTENT_DIR="$DEVFLOW_DIR/decisions"

# Normal logging
source "$SCRIPT_DIR/hook-log-init" "session-start-context"

# Read sidecar config for feature state (primary source of truth)
_SIDECAR_CONFIG="$SIDECAR_DIR/config.json"
_LEARNING_SIDECAR="true"
if [ -f "$_SIDECAR_CONFIG" ]; then
  _LEARNING_SIDECAR=$(json_field_file "$_SIDECAR_CONFIG" "learning" "true")
fi

dbg "LEARNING_SIDECAR=$_LEARNING_SIDECAR"

# --- Section 1.4: Learning Manifest Reconciliation ---
# DESIGN: D6 — reconciler runs at session-start to amortize filesystem checks
# across session boundaries rather than on every tool call.
# Silently ignores errors — a failed reconcile is non-fatal.
# Skipped if learning feature is disabled via sentinel or sidecar config.

if [ "$_LEARNING_SIDECAR" = "true" ] && [ ! -f "$MEMORY_DIR/.learning-disabled" ]; then
  dbg "Running learning manifest reconciliation"
  if [ -f "$LEARNING_DIR/.learning-manifest.json" ] && [ -f "$LEARNING_DIR/learning-log.jsonl" ]; then
    node "$_JSON_HELPER" reconcile-manifest "$CWD" 2>/dev/null || true
  fi

  # Reconcile decisions manifest (still done here even if decisions disabled — manifest is learning's)
  if [ -f "$DECISIONS_CONTENT_DIR/decisions-log.jsonl" ]; then
    node "$_JSON_HELPER" reconcile-manifest "$CWD" "$DECISIONS_CONTENT_DIR/decisions-log.jsonl" "$DECISIONS_CONTENT_DIR/.decisions-manifest.json" 2>/dev/null || true
  fi
fi

# --- Section 1.5: Project Decisions TL;DR ---
# Skipped if decisions feature is disabled via sentinel.
if [ ! -f "$DECISIONS_CONTENT_DIR/.disabled" ]; then
  DECISIONS_DIR="$DECISIONS_CONTENT_DIR"
  # Heal older installs that have .devflow/ but not .devflow/decisions/
  if [ -d "$DEVFLOW_DIR" ] && [ ! -d "$DECISIONS_DIR" ]; then
    mkdir -p "$DECISIONS_DIR" 2>/dev/null || true
  fi
  if [ -d "$DECISIONS_DIR" ]; then
    DECISIONS_TLDR=""
    for kf in "$DECISIONS_DIR"/decisions.md "$DECISIONS_DIR"/pitfalls.md; do
      if [ -f "$kf" ]; then
        TLDR_LINE=$(sed -n '1s/<!-- TL;DR: \(.*\) -->/\1/p' "$kf")
        if [ -n "$TLDR_LINE" ]; then
          DECISIONS_TLDR="${DECISIONS_TLDR}${TLDR_LINE}\n"
        fi
      fi
    done
    if [ -n "$DECISIONS_TLDR" ]; then
      dbg "Decisions TL;DR found"
      DECISIONS_SECTION="--- PROJECT DECISIONS (TL;DR) ---
$(printf '%b' "$DECISIONS_TLDR")"
      if [ -n "$CONTEXT" ]; then
        CONTEXT="${CONTEXT}

${DECISIONS_SECTION}"
      else
        CONTEXT="$DECISIONS_SECTION"
      fi
    fi
  fi
fi

# --- Section 1.75: Learned Behaviors ---
# Skipped if learning feature is disabled via sentinel or sidecar config.
#
# _build_learned_section LEARNING_LOG NOTIFIED_MARKER
#   Prints the LEARNED BEHAVIORS block to stdout, or nothing if no artifacts exist.
#   Side-effect: updates NOTIFIED_MARKER when new artifacts are present.
_build_learned_section() {
  local log_file="$1" notified_marker="$2"

  # Single-pass extraction of created artifacts (commands + skills)
  local learned_json
  learned_json=$(json_learning_created "$log_file")

  local learned_commands="" learned_skills=""
  if [ -n "$learned_json" ]; then
    if [ "$_HAS_JQ" = "true" ]; then
      learned_commands=$(echo "$learned_json" | jq -r '.commands | map("/self-learning/\(.name) (\(.conf))") | join(", ")' 2>/dev/null)
      learned_skills=$(echo "$learned_json" | jq -r '.skills | map("\(.name) (\(.conf))") | join(", ")' 2>/dev/null)
    else
      # Node fallback: parse the JSON and format
      learned_commands=$(echo "$learned_json" | node -e "
        const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
        console.log(d.commands.map(c=>\"/self-learning/\"+c.name+\" (\"+c.conf+\")\").join(', '));
      " 2>/dev/null)
      learned_skills=$(echo "$learned_json" | node -e "
        const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
        console.log(d.skills.map(s=>s.name+\" (\"+s.conf+\")\").join(', '));
      " 2>/dev/null)
    fi
  fi

  if [ "${DEVFLOW_HOOK_DEBUG:-}" = "1" ]; then dbg "Learned artifacts: commands=$(echo "$learned_commands" | grep -c , 2>/dev/null || echo 0) skills=$(echo "$learned_skills" | grep -c , 2>/dev/null || echo 0)"; fi
  [ -z "$learned_commands" ] && [ -z "$learned_skills" ] && return 0

  local section="--- LEARNED BEHAVIORS ---"
  [ -n "$learned_commands" ] && section="${section}
Commands: $learned_commands"
  [ -n "$learned_skills" ] && section="${section}
Skills: $learned_skills"
  section="${section}
Edit or delete: .claude/commands/self-learning/ and .claude/skills/"

  # Check for new artifacts since last notification (single jq -s pass)
  local last_notified=0
  [ -f "$notified_marker" ] && last_notified=$(cat "$notified_marker" 2>/dev/null || echo "0")

  local new_artifacts
  new_artifacts=$(json_learning_new "$log_file" "$last_notified")

  if [ -n "$new_artifacts" ]; then
    section="${section}

--- NEW LEARNED BEHAVIORS ---
${new_artifacts}
TIP: Type the command name to use it. Rename to shorter path for quicker access.
Run \`devflow learn --list\` to see all."
    # Only update notified marker when new artifacts exist
    date +%s > "$notified_marker" 2>/dev/null || true
  fi

  printf '%s' "$section"
}

if [ "$_LEARNING_SIDECAR" = "true" ] && [ ! -f "$MEMORY_DIR/.learning-disabled" ]; then
  LEARNING_LOG="$LEARNING_DIR/learning-log.jsonl"
  NOTIFIED_MARKER="$LEARNING_DIR/.learning-notified-at"

  if [ -f "$LEARNING_LOG" ]; then
    LEARNED_SECTION=$(_build_learned_section "$LEARNING_LOG" "$NOTIFIED_MARKER")
    if [ -n "$LEARNED_SECTION" ]; then
      if [ -n "$CONTEXT" ]; then
        CONTEXT="${CONTEXT}

${LEARNED_SECTION}"
      else
        CONTEXT="$LEARNED_SECTION"
      fi
    fi
  fi
fi

# --- Output ---

# Only output if we have something to inject
if [ -z "$CONTEXT" ]; then
  dbg "EXIT: no context to inject"
  exit 0
fi

dbg "OUTPUT_LENGTH=${#CONTEXT}"
log "Injecting context (${#CONTEXT} chars)"
dbg "=== HOOK COMPLETE ==="

# Output as additionalContext JSON envelope (Claude sees it as system context, not user-visible)
json_session_output "$CONTEXT"
