#!/bin/bash
# dream-evaluate: Learning evaluation module.
# Accumulates session IDs and triggers learning marker when batch threshold is reached.
# Source from dream-evaluate orchestrator after eval-helpers.
#
# Requires (from orchestrator namespace):
#   LEARNING_ENABLED, SESSION_DEEP, SESSION_ID, DREAM_DIR, LEARNING_DIR,
#   FILTER_LIB, TRANSCRIPT, NOW, TODAY, MARKER_SUFFIX,
#   _HAS_JQ, json_field_file(), log(), dbg(),
#   read_daily_cap(), atomic_increment_daily(), load_existing_ids(),
#   dream_lock_acquire(), dream_lock_release(), _eval_release_lock()

: "${DREAM_DIR:?eval-learning: DREAM_DIR must be set by orchestrator}"
: "${LEARNING_DIR:?eval-learning: LEARNING_DIR must be set by orchestrator}"
: "${NOW:?eval-learning: NOW must be set by orchestrator}"
: "${TODAY:?eval-learning: TODAY must be set by orchestrator}"
: "${MARKER_SUFFIX:?eval-learning: MARKER_SUFFIX must be set by orchestrator}"
: "${_HAS_JQ:?eval-learning: _HAS_JQ must be set by orchestrator}"

if [ "$LEARNING_ENABLED" = "true" ] && [ "$SESSION_DEEP" = "true" ]; then
  log "Evaluating learning..."

  # Load learning config
  _LEARN_CONFIG="$LEARNING_DIR/learning.json"
  _LEARN_MAX_DAILY=5
  _LEARN_BATCH_SIZE=3

  if [ -f "$_LEARN_CONFIG" ]; then
    _LEARN_MAX_DAILY=$(json_field_file "$_LEARN_CONFIG" "max_daily_runs" "5")
    _LEARN_BATCH_SIZE=$(json_field_file "$_LEARN_CONFIG" "batch_size" "3")
  fi
  _LEARN_MAX_DAILY=$(echo "$_LEARN_MAX_DAILY" | tr -dc '0-9')
  _LEARN_MAX_DAILY="${_LEARN_MAX_DAILY:-5}"
  _LEARN_BATCH_SIZE=$(echo "$_LEARN_BATCH_SIZE" | tr -dc '0-9')
  _LEARN_BATCH_SIZE="${_LEARN_BATCH_SIZE:-3}"

  # Adaptive batch size
  _LEARN_OBS_TOTAL=0
  if [ -f "$LEARNING_DIR/learning-log.jsonl" ]; then
    _LEARN_OBS_TOTAL=$(wc -l < "$LEARNING_DIR/learning-log.jsonl" | tr -d ' ')
  fi
  if [ "$_LEARN_OBS_TOTAL" -ge 15 ]; then
    _LEARN_BATCH_SIZE=5
  fi

  # Daily cap check
  _LEARN_RUNS_FILE="$DREAM_DIR/.learning-runs-today"
  _LEARN_RUNS_TODAY=$(read_daily_cap "$_LEARN_RUNS_FILE" 0)

  dbg "Learning: RUNS_TODAY=$_LEARN_RUNS_TODAY MAX_DAILY=$_LEARN_MAX_DAILY BATCH_SIZE=$_LEARN_BATCH_SIZE"
  if [ "$_LEARN_RUNS_TODAY" -ge "$_LEARN_MAX_DAILY" ]; then
    log "Learning daily cap reached ($_LEARN_RUNS_TODAY/$_LEARN_MAX_DAILY)"
    dbg "Learning daily cap reached — skipping"
  else
    # Batch counting — accumulate session IDs
    _LEARN_SESSION_COUNT_FILE="$DREAM_DIR/.learning-sessions"
    _LEARN_CURRENT_COUNT=0

    # Validate session ID format
    if [ -n "$SESSION_ID" ] && echo "$SESSION_ID" | grep -qE '^[a-zA-Z0-9_-]+$'; then
      # Deduplicate
      if [ -f "$_LEARN_SESSION_COUNT_FILE" ] && grep -qxF "$SESSION_ID" "$_LEARN_SESSION_COUNT_FILE" 2>/dev/null; then
        log "Learning: session already counted"
      else
        echo "$SESSION_ID" >> "$_LEARN_SESSION_COUNT_FILE"
      fi
    fi

    if [ -f "$_LEARN_SESSION_COUNT_FILE" ]; then
      _LEARN_CURRENT_COUNT=$(wc -l < "$_LEARN_SESSION_COUNT_FILE" | tr -d ' ')
    fi
    log "Learning batch: $_LEARN_CURRENT_COUNT/$_LEARN_BATCH_SIZE sessions"

    # _learn_write_marker: called under lock with validated count >= batch_size.
    # Extracts user signals and writes a per-session learning marker.
    # Returns 0 if marker written, 1 if no user signals found.
    _learn_write_marker() {
      local count="$1" session_count_file="$2"
      # Extract user signals from transcript
      local user_signals=""
      if [ -f "$FILTER_LIB" ] && [ -n "$TRANSCRIPT" ] && [ -f "$TRANSCRIPT" ]; then
        user_signals=$(node "$FILTER_LIB" user-signals "$TRANSCRIPT" 2>/dev/null || true)
      fi
      if [ -z "$user_signals" ]; then
        log "Learning: no user signals extracted from transcript"
        dbg "Learning: no user signals in transcript"
        return 1
      fi
      local existing_ids
      existing_ids=$(load_existing_ids "$LEARNING_DIR/learning-log.jsonl")
      local marker="$DREAM_DIR/learning.${MARKER_SUFFIX}.json"
      local tmp="${marker}.tmp.$$"
      if [ "$_HAS_JQ" = "true" ]; then
        jq -n \
          --arg userSignals "$user_signals" \
          --argjson existingObservationIds "$existing_ids" \
          --argjson timestamp "$NOW" \
          '{userSignals: $userSignals, existingObservationIds: $existingObservationIds, timestamp: $timestamp}' \
          > "$tmp" && mv "$tmp" "$marker" || rm -f "$tmp"
      else
        node -e "
          process.stdout.write(JSON.stringify({
            userSignals: process.argv[1],
            existingObservationIds: JSON.parse(process.argv[2]),
            timestamp: parseInt(process.argv[3])
          }) + '\n')
        " -- "$user_signals" "$existing_ids" "$NOW" > "$tmp" && mv "$tmp" "$marker" || rm -f "$tmp"
      fi
      atomic_increment_daily "$_LEARN_RUNS_FILE" "$TODAY"
      rm -f "$session_count_file"
      log "Wrote learning marker (batch of $count sessions)"
      dbg "Wrote learning marker: $marker"
    }

    if [ "$_LEARN_CURRENT_COUNT" -ge "$_LEARN_BATCH_SIZE" ] && [ -f "$_LEARN_SESSION_COUNT_FILE" ]; then
      if dream_lock_acquire "$DREAM_DIR/.learning-batch.lock" 3; then
        trap '_eval_release_lock "$DREAM_DIR/.learning-batch.lock"' EXIT
        # Re-read count under lock
        if [ -f "$_LEARN_SESSION_COUNT_FILE" ]; then
          _LEARN_CURRENT_COUNT=$(wc -l < "$_LEARN_SESSION_COUNT_FILE" | tr -d ' ')
        fi
        # Cap session file at 50 lines (inside lock to prevent multi-session race)
        if [ "$_LEARN_CURRENT_COUNT" -gt 50 ]; then
          _LEARN_SC_TMP="$_LEARN_SESSION_COUNT_FILE.tmp.$$"
          tail -50 "$_LEARN_SESSION_COUNT_FILE" > "$_LEARN_SC_TMP" && mv "$_LEARN_SC_TMP" "$_LEARN_SESSION_COUNT_FILE" || rm -f "$_LEARN_SC_TMP"
          _LEARN_CURRENT_COUNT=50
        fi
        if [ "$_LEARN_CURRENT_COUNT" -ge "$_LEARN_BATCH_SIZE" ] && [ -f "$_LEARN_SESSION_COUNT_FILE" ]; then
          _learn_write_marker "$_LEARN_CURRENT_COUNT" "$_LEARN_SESSION_COUNT_FILE"
        fi
        dream_lock_release "$DREAM_DIR/.learning-batch.lock"
        trap - EXIT
      else
        log "Learning batch skipped: could not acquire lock"
      fi
    fi
  fi
fi
