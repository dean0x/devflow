#!/bin/bash

# Sidecar System: sidecar-capture (Stop Hook)
# Captures assistant responses to .devflow/memory/.pending-turns.jsonl queue.
# Writes .devflow/sidecar/memory.json marker when throttle has expired (>2 min).
# On failure: does nothing (stale memory is better than fake data).

# Safe no-op fallback: must exist before set -e and before debug-trace is sourced.
dbg() { :; }

set -e

# Resolve script directory once
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$SCRIPT_DIR/debug-trace" || true
devflow_debug_init "sidecar-capture"
dbg "=== HOOK START ==="

# Break feedback loop: sidecar subagents trigger stop hook on exit.
if [ "${DEVFLOW_BG_UPDATER:-}" = "1" ]; then dbg "EXIT: bg_updater"; exit 0; fi
if [ "${DEVFLOW_BG_LEARNER:-}" = "1" ]; then dbg "EXIT: bg_learner"; exit 0; fi
if [ "${DEVFLOW_BG_KNOWLEDGE_REFRESH:-}" = "1" ]; then dbg "EXIT: bg_knowledge"; exit 0; fi

# JSON parsing (jq with node fallback)
source "$SCRIPT_DIR/json-parse" || { echo "sidecar-capture: failed to source json-parse" >&2; exit 1; }
if [ "$_JSON_AVAILABLE" = "false" ]; then dbg "EXIT: no json"; exit 0; fi

dbg "json available, has_jq=$_HAS_JQ"

INPUT=$(cat)
dbg "INPUT length=${#INPUT}"
if [ "${DEVFLOW_HOOK_DEBUG:-}" = "1" ]; then dbg "INPUT keys=$(printf '%s' "$INPUT" | jq -r 'keys | join(", ")' 2>/dev/null || echo 'jq-failed')"; fi

# Resolve project directory and assistant response in one subprocess.
# Stop hook fields: cwd, last_assistant_message, session_id, transcript_path, etc.
# Uses ASCII SOH (0x01) as delimiter for bash 3.2 compatibility with cut.
if [ "$_HAS_JQ" = "true" ]; then
  _FIELDS=$(printf '%s' "$INPUT" | jq -r '(.cwd // "") + "" + (.last_assistant_message // "")') || { dbg "EXIT: jq failed"; exit 0; }
else
  _FIELDS=$(printf '%s' "$INPUT" | node -e "
    const j=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
    process.stdout.write((j.cwd||'')+'\x01'+(j.last_assistant_message||''))") || { dbg "EXIT: node failed"; exit 0; }
fi
CWD=$(printf '%s' "$_FIELDS" | cut -d$'\001' -f1)
RESPONSE_TEXT=$(printf '%s' "$_FIELDS" | cut -d$'\001' -f2-)

if [ -z "$CWD" ] || [ ! -d "$CWD" ]; then dbg "EXIT: bad CWD"; exit 0; fi

devflow_debug_set_cwd "$CWD"
dbg "CWD=$CWD"
dbg "RESPONSE_TEXT length=${#RESPONSE_TEXT}"

DEVFLOW_DIR="$CWD/.devflow"
MEMORY_DIR="$DEVFLOW_DIR/memory"
SIDECAR_DIR="$DEVFLOW_DIR/sidecar"

# Read sidecar config — memory:false gates memory-specific sections only.
# The decisions usage scanner runs independently of memory state.
SIDECAR_CONFIG="$SIDECAR_DIR/config.json"
MEMORY_ENABLED="true"
if [ -f "$SIDECAR_CONFIG" ]; then
  MEMORY_ENABLED=$(json_field_file "$SIDECAR_CONFIG" "memory" "true")
fi

dbg "MEMORY_ENABLED=$MEMORY_ENABLED"

# Skip if empty response
if [ -z "$RESPONSE_TEXT" ]; then
  dbg "EXIT: empty RESPONSE_TEXT"
  exit 0
fi

dbg "PASSED all checks, proceeding to capture"

# Truncate to 2000 chars
if [ ${#RESPONSE_TEXT} -gt 2000 ]; then
  RESPONSE_TEXT="${RESPONSE_TEXT:0:2000}... [truncated]"
fi

# --- Decisions usage scanner (independent of memory state) ---
# D29: Supplementary — skip Node spawn when no ADR/PF citations present (~50-100ms savings).
SCANNER="$SCRIPT_DIR/decisions-usage-scan.cjs"
if [ -f "$SCANNER" ] && [ ! -f "$DEVFLOW_DIR/decisions/.disabled" ]; then
  if printf '%s' "$RESPONSE_TEXT" | grep -qE 'ADR-[0-9]+|PF-[0-9]+'; then
    dbg "Running decisions usage scanner"
    printf '%s' "$RESPONSE_TEXT" | node "$SCANNER" --cwd "$CWD" 2>/dev/null || true
  fi
fi

# --- Memory-specific sections (gated by memory:false in sidecar config) ---
if [ "$MEMORY_ENABLED" = "false" ]; then
  dbg "EXIT: memory disabled"
  exit 0
fi

# Logging (needs CWD and memory-enabled path — source after memory gate so log-paths
# subprocess overhead (~15-20ms) is only paid when memory is actually enabled)
source "$SCRIPT_DIR/log-paths" || true
LOG_DIR=$(devflow_log_dir "$CWD" 2>/dev/null || echo "${TMPDIR:-/tmp}")
LOG_FILE="$LOG_DIR/.working-memory-update.log"
# Size guard: truncate log to tail 1MB when it exceeds 2MB (runs once per hook invocation)
if [ -f "$LOG_FILE" ] && [ "$(wc -c < "$LOG_FILE" 2>/dev/null || echo 0)" -gt 2097152 ]; then
  _LTMP="$LOG_FILE.tmp.$$"
  tail -c 1048576 "$LOG_FILE" > "$_LTMP" 2>/dev/null && mv "$_LTMP" "$LOG_FILE" 2>/dev/null || rm -f "$_LTMP" 2>/dev/null || true
fi
log() { echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [sidecar-capture] $1" >> "$LOG_FILE" 2>/dev/null || true; }

# Auto-create .devflow/ and ensure .gitignore entries
source "$SCRIPT_DIR/ensure-devflow-init" "$CWD" || exit 0

source "$SCRIPT_DIR/get-mtime" || { echo "sidecar-capture: failed to source get-mtime" >&2; exit 1; }
source "$SCRIPT_DIR/sidecar-lock" || { echo "sidecar-capture: failed to source sidecar-lock" >&2; exit 1; }

# --- Append to queue ---
QUEUE_FILE="$MEMORY_DIR/.pending-turns.jsonl"

# Ensure queue file has restricted permissions (600) if not yet created.
if [ ! -f "$QUEUE_FILE" ]; then
  (umask 077 && touch "$QUEUE_FILE") 2>/dev/null || true
fi

TS=$(date +%s)
if [ "$_HAS_JQ" = "true" ]; then
  jq -n -c --arg role "assistant" --arg content "$RESPONSE_TEXT" --argjson ts "$TS" \
    '{role: $role, content: $content, ts: $ts}' >> "$QUEUE_FILE"
else
  node -e "process.stdout.write(JSON.stringify({role:'assistant',content:process.argv[1],ts:parseInt(process.argv[2])})+'\n')" \
    -- "$RESPONSE_TEXT" "$TS" >> "$QUEUE_FILE"
fi

dbg "Appended to queue: QUEUE_FILE=$QUEUE_FILE"

# Queue overflow safety: if >200 lines, keep last 100 (locked to prevent multi-session race)
if [ -f "$QUEUE_FILE" ]; then
  LINE_COUNT=$(wc -l < "$QUEUE_FILE" | tr -d ' ')
  if [ "$LINE_COUNT" -gt 200 ]; then
    _QUEUE_LOCK="$MEMORY_DIR/.pending-turns.lock"
    if sidecar_lock_acquire "$_QUEUE_LOCK" 2; then
      LINE_COUNT=$(wc -l < "$QUEUE_FILE" | tr -d ' ')
      if [ "$LINE_COUNT" -gt 200 ]; then
        _TRUNC_TMP="$QUEUE_FILE.tmp.$$" && tail -100 "$QUEUE_FILE" > "$_TRUNC_TMP" && mv "$_TRUNC_TMP" "$QUEUE_FILE" || rm -f "$_TRUNC_TMP"
        log "Queue overflow: truncated from $LINE_COUNT to 100 lines"
        dbg "Queue overflow: truncated from $LINE_COUNT to 100 lines"
      fi
      sidecar_lock_release "$_QUEUE_LOCK"
    fi
  fi
fi

log "Captured assistant turn (${#RESPONSE_TEXT} chars)"

# --- Write memory marker if throttle expired ---
# Skip if a .processing file already exists (in-flight update)
PROCESSING_MARKER="$SIDECAR_DIR/memory.processing"
if [ -f "$PROCESSING_MARKER" ]; then
  log "Throttled: memory.processing exists (in-flight sidecar update)"
  dbg "EXIT: memory.processing exists"
  exit 0
fi

# Check time since last memory update or last marker
WORKING_MEMORY="$MEMORY_DIR/WORKING-MEMORY.md"
NOW=$(date +%s)
LAST_UPDATE=0

if [ -f "$WORKING_MEMORY" ]; then
  LAST_UPDATE=$(get_mtime "$WORKING_MEMORY")
fi
LAST_UPDATE="${LAST_UPDATE:-0}"

AGE=$(( NOW - LAST_UPDATE ))
if [ "$AGE" -lt 120 ]; then
  log "Throttled: WORKING-MEMORY.md updated ${AGE}s ago"
  dbg "EXIT: throttled AGE=${AGE}s"
  exit 0
fi

dbg "Throttle passed: AGE=${AGE}s >= 120s — writing memory marker"

# Write memory marker
mkdir -p "$SIDECAR_DIR"

_MEM_TMP="$SIDECAR_DIR/memory.json.tmp.$$"
if [ "$_HAS_JQ" = "true" ]; then
  jq -n \
    --arg pendingTurnsFile "$QUEUE_FILE" \
    --arg existingMemoryFile "$WORKING_MEMORY" \
    --arg model "haiku" \
    --argjson timestamp "$NOW" \
    '{pendingTurnsFile: $pendingTurnsFile, existingMemoryFile: $existingMemoryFile, model: $model, timestamp: $timestamp}' \
    > "$_MEM_TMP" && mv "$_MEM_TMP" "$SIDECAR_DIR/memory.json" || rm -f "$_MEM_TMP"
else
  node -e "
    process.stdout.write(JSON.stringify({
      pendingTurnsFile: process.argv[1],
      existingMemoryFile: process.argv[2],
      model: 'haiku',
      timestamp: parseInt(process.argv[3])
    }) + '\n')
  " -- "$QUEUE_FILE" "$WORKING_MEMORY" "$NOW" > "$_MEM_TMP" && mv "$_MEM_TMP" "$SIDECAR_DIR/memory.json" || rm -f "$_MEM_TMP"
fi

log "Wrote memory marker: $SIDECAR_DIR/memory.json"
dbg "=== HOOK COMPLETE ==="

exit 0
