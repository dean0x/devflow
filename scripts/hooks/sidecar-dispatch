#!/bin/bash

# Sidecar System: sidecar-dispatch (UserPromptSubmit Hook)
# 1. Captures user turn to .memory/.pending-turns.jsonl
# 2. Checks for pending sidecar markers in .memory/.sidecar/
# 3. If markers found, injects SIDECAR directive via additionalContext

set -e

# Break feedback loop from background sidecar sessions
if [ "${DEVFLOW_BG_UPDATER:-}" = "1" ]; then exit 0; fi
if [ "${DEVFLOW_BG_LEARNER:-}" = "1" ]; then exit 0; fi
if [ "${DEVFLOW_BG_KNOWLEDGE_REFRESH:-}" = "1" ]; then exit 0; fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/json-parse" || { echo "sidecar-dispatch: failed to source json-parse" >&2; exit 1; }
source "$SCRIPT_DIR/get-mtime" || { echo "sidecar-dispatch: failed to source get-mtime" >&2; exit 1; }
if [ "$_JSON_AVAILABLE" = "false" ]; then exit 0; fi

INPUT=$(cat)

FIELDS=$(printf '%s' "$INPUT" | json_extract_cwd_prompt)
CWD="${FIELDS%%$'\001'*}"
PROMPT="${FIELDS#*$'\001'}"

if [ -z "$CWD" ] || [ ! -d "$CWD" ]; then exit 0; fi

MEMORY_DIR="$CWD/.memory"
SIDECAR_DIR="$MEMORY_DIR/.sidecar"

# Read sidecar config — skip user turn capture if memory: false; gate marker dispatch per feature
SIDECAR_CONFIG="$SIDECAR_DIR/config.json"
MEMORY_ENABLED="true"
LEARNING_ENABLED="true"
DECISIONS_ENABLED="true"
KNOWLEDGE_ENABLED="true"
if [ -f "$SIDECAR_CONFIG" ]; then
  MEMORY_ENABLED=$(json_field_file "$SIDECAR_CONFIG" "memory" "true")
  LEARNING_ENABLED=$(json_field_file "$SIDECAR_CONFIG" "learning" "true")
  DECISIONS_ENABLED=$(json_field_file "$SIDECAR_CONFIG" "decisions" "true")
  KNOWLEDGE_ENABLED=$(json_field_file "$SIDECAR_CONFIG" "knowledge" "true")
fi

# --- Capture user turn ---
if [ "$MEMORY_ENABLED" = "true" ] && [ -n "$PROMPT" ]; then
  source "$SCRIPT_DIR/ensure-memory-gitignore" "$CWD" || true

  # Truncate to 2000 chars
  if [ ${#PROMPT} -gt 2000 ]; then
    PROMPT="${PROMPT:0:2000}... [truncated]"
  fi

  QUEUE_FILE="$MEMORY_DIR/.pending-turns.jsonl"

  # Ensure queue file is created with restricted permissions (600) before first write.
  if [ ! -f "$QUEUE_FILE" ]; then
    (umask 077 && touch "$QUEUE_FILE") 2>/dev/null || true
  fi

  TS=$(date +%s)
  if [ "$_HAS_JQ" = "true" ]; then
    jq -n -c --arg role "user" --arg content "$PROMPT" --argjson ts "$TS" \
      '{role: $role, content: $content, ts: $ts}' >> "$QUEUE_FILE"
  else
    node -e "process.stdout.write(JSON.stringify({role:'user',content:process.argv[1],ts:parseInt(process.argv[2])})+'\n')" \
      -- "$PROMPT" "$TS" >> "$QUEUE_FILE"
  fi
fi

# --- Check for pending sidecar markers ---
# Skip if sidecar dir doesn't exist
if [ ! -d "$SIDECAR_DIR" ]; then
  exit 0
fi

# Stale retry: if any .processing file is >5 min old, rename back to .json.
# Cap at 10 files to guard against unexpected proliferation.
# After MAX_RETRIES stale recoveries, mark as .failed instead of cycling.
NOW=$(date +%s)
MAX_RETRIES=3

# Track markers recovered from stale .processing in this call — their .retries must
# persist to the next call so the retry counter survives until dispatch can use it.
JUST_RECOVERED=""

# Guard: only enter stale-retry loop when .processing files actually exist.
# This avoids the glob expansion cost (get_mtime + stat calls) on every prompt.
if compgen -G "$SIDECAR_DIR/*.processing" > /dev/null 2>&1; then
  PROC_COUNT=0
  PROC_LIMIT=10
  for PROC_FILE in "$SIDECAR_DIR"/*.processing; do
    [ -f "$PROC_FILE" ] || continue
    PROC_COUNT=$(( PROC_COUNT + 1 ))
    [ "$PROC_COUNT" -gt "$PROC_LIMIT" ] && break
    PROC_MTIME=$(get_mtime "$PROC_FILE")
    PROC_MTIME="${PROC_MTIME:-0}"
    PROC_AGE=$(( NOW - PROC_MTIME ))
    if [ "$PROC_AGE" -gt 300 ]; then
      # Check how many times this marker has already been retried
      BASE="${PROC_FILE%.processing}"
      RETRY_FILE="${BASE}.retries"
      RETRY_COUNT=0
      if [ -f "$RETRY_FILE" ]; then
        # Sanitize: strip non-digits to guard against corrupted .retries files causing
        # arithmetic errors under set -e.
        RETRY_COUNT=$(cat "$RETRY_FILE" 2>/dev/null | tr -dc '0-9' || true)
        RETRY_COUNT="${RETRY_COUNT:-0}"
      fi
      if [ "$RETRY_COUNT" -ge "$MAX_RETRIES" ]; then
        # Too many retries — mark as permanently failed to stop cycling
        mv "$PROC_FILE" "${BASE}.failed" 2>/dev/null || true
        rm -f "$RETRY_FILE" 2>/dev/null || true
      else
        # Stale processing file — rename back to .json for retry; record basename so the
        # collection loop knows not to clean the .retries file for this marker in this call.
        echo $(( RETRY_COUNT + 1 )) > "$RETRY_FILE"
        mv "$PROC_FILE" "${BASE}.json" 2>/dev/null || true
        JUST_RECOVERED="$JUST_RECOVERED $(basename "$BASE")"
      fi
    fi
  done
fi

# Collect pending markers (exclude config.json)
# Markers with a timestamp field older than 24h are expired — delete and skip.
# Skip markers whose feature is currently disabled in config (avoids dispatching stale markers
# after a feature is turned off between write-time and dispatch-time).
PENDING_TASKS=""
for MARKER_FILE in "$SIDECAR_DIR"/*.json; do
  [ -f "$MARKER_FILE" ] || continue
  BASENAME=$(basename "$MARKER_FILE" .json)
  # Skip config
  [ "$BASENAME" = "config" ] && continue
  # Skip marker if its feature is currently disabled — remove the stale marker to prevent
  # it accumulating indefinitely after a feature is turned off.
  case "$BASENAME" in
    learning)   [ "$LEARNING_ENABLED"  != "true" ] && { rm -f "$MARKER_FILE" 2>/dev/null || true; continue; } ;;
    decisions)  [ "$DECISIONS_ENABLED" != "true" ] && { rm -f "$MARKER_FILE" 2>/dev/null || true; continue; } ;;
    knowledge)  [ "$KNOWLEDGE_ENABLED" != "true" ] && { rm -f "$MARKER_FILE" 2>/dev/null || true; continue; } ;;
  esac
  # Expire markers older than 24h (86400s) when they carry a timestamp field.
  if [ "$_HAS_JQ" = "true" ]; then
    MARKER_TS=$(jq '.timestamp // empty' "$MARKER_FILE" 2>/dev/null || true)
    if [ -n "$MARKER_TS" ] && [ "$MARKER_TS" -gt 0 ] 2>/dev/null; then
      MARKER_AGE=$(( NOW - MARKER_TS ))
      if [ "$MARKER_AGE" -gt 86400 ]; then
        rm -f "$MARKER_FILE" 2>/dev/null || true
        continue
      fi
    fi
  fi
  # Clean up any stale .retries file for this marker, unless the marker was just recovered
  # from stale .processing in this same call (in which case the .retries counter must survive
  # to the next call so it isn't reset before the retry limit can be enforced).
  case " $JUST_RECOVERED " in
    *" $BASENAME "*) ;;  # Just recovered — leave .retries in place
    *) rm -f "${MARKER_FILE%.json}.retries" 2>/dev/null || true ;;
  esac
  if [ -n "$PENDING_TASKS" ]; then
    PENDING_TASKS="$PENDING_TASKS,$BASENAME"
  else
    PENDING_TASKS="$BASENAME"
  fi
done

# If no pending tasks, exit silently (no additionalContext output)
if [ -z "$PENDING_TASKS" ]; then
  exit 0
fi

# Output SIDECAR directive
DIRECTIVE="SIDECAR: ${PENDING_TASKS}. Spawn background agents — load devflow:sidecar skill."
json_prompt_output "$DIRECTIVE"

exit 0
