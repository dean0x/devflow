#!/bin/bash

# Sidecar System: sidecar-evaluate (SessionEnd Hook)
# Evaluates session-level features: learning batching, decisions detection, knowledge refresh.
# Writes marker files to .devflow/sidecar/ for sidecar-dispatch to pick up.
#
# Orchestrator: sources eval-helpers + 4 feature modules after shared setup.

# Safe no-op fallback: must exist before set -e and before hook-bootstrap is sourced.
dbg() { :; }

set -e

# Feedback-loop guards — before hook-bootstrap to minimize background session overhead
# Order: UPDATER, LEARNER, KNOWLEDGE — consistent with sidecar-capture and sidecar-dispatch.
# dbg() is the pre-bootstrap no-op here; annotations are safe but silent without debug active.
if [ "${DEVFLOW_BG_UPDATER:-}" = "1" ]; then dbg "EXIT: bg_updater"; exit 0; fi
if [ "${DEVFLOW_BG_LEARNER:-}" = "1" ]; then dbg "EXIT: bg_learner"; exit 0; fi
if [ "${DEVFLOW_BG_KNOWLEDGE_REFRESH:-}" = "1" ]; then dbg "EXIT: bg_knowledge"; exit 0; fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$SCRIPT_DIR/hook-bootstrap" "sidecar-evaluate"

source "$SCRIPT_DIR/json-parse" || { echo "sidecar-evaluate: failed to source json-parse" >&2; exit 1; }
if [ "$_JSON_AVAILABLE" = "false" ]; then dbg "EXIT: no json"; exit 0; fi

INPUT=$(cat)

CWD=$(printf '%s' "$INPUT" | json_field "cwd" "")
if [ -z "$CWD" ] || [ ! -d "$CWD" ]; then dbg "EXIT: bad CWD"; exit 0; fi

devflow_debug_set_cwd "$CWD"
dbg "CWD=$CWD"

DEVFLOW_DIR="$CWD/.devflow"
[ ! -d "$DEVFLOW_DIR" ] && exit 0

MEMORY_DIR="$DEVFLOW_DIR/memory"
FEATURES_DIR="$DEVFLOW_DIR/features"
SIDECAR_DIR="$DEVFLOW_DIR/sidecar"
LEARNING_DIR="$DEVFLOW_DIR/learning"
DECISIONS_DIR_DATA="$DEVFLOW_DIR/decisions"

# Read sidecar config
SIDECAR_CONFIG="$SIDECAR_DIR/config.json"
LEARNING_ENABLED="true"
DECISIONS_ENABLED="true"
KNOWLEDGE_ENABLED="true"

if [ -f "$SIDECAR_CONFIG" ]; then
  LEARNING_ENABLED=$(json_field_file "$SIDECAR_CONFIG" "learning" "true")
  DECISIONS_ENABLED=$(json_field_file "$SIDECAR_CONFIG" "decisions" "true")
  KNOWLEDGE_ENABLED=$(json_field_file "$SIDECAR_CONFIG" "knowledge" "true")
fi

# Log + sidecar-lock
source "$SCRIPT_DIR/hook-log-init" "sidecar-evaluate"
source "$SCRIPT_DIR/sidecar-lock" || { log "failed to source sidecar-lock"; exit 1; }

log "SessionEnd hook triggered"
dbg "LEARNING=$LEARNING_ENABLED DECISIONS=$DECISIONS_ENABLED KNOWLEDGE=$KNOWLEDGE_ENABLED"

# --- Find transcript ---
ENCODED_CWD=$(echo "$CWD" | sed 's|^/||' | tr '/' '-')
PROJECTS_DIR="$HOME/.claude/projects/-${ENCODED_CWD}"

SESSION_ID=$(printf '%s' "$INPUT" | json_field "session_id" "")
dbg "SESSION_ID=$SESSION_ID"
TRANSCRIPT=""

if [ -d "$PROJECTS_DIR" ]; then
  # Validate session_id before use in path — guard against path traversal (../ sequences)
  if [ -n "$SESSION_ID" ] && echo "$SESSION_ID" | grep -qE '^[a-zA-Z0-9_-]+$' && [ -f "$PROJECTS_DIR/${SESSION_ID}.jsonl" ]; then
    TRANSCRIPT="$PROJECTS_DIR/${SESSION_ID}.jsonl"
  else
    TRANSCRIPT=$(ls -t "$PROJECTS_DIR"/*.jsonl 2>/dev/null | head -1 || true)
    [ -z "$TRANSCRIPT" ] || [ ! -f "$TRANSCRIPT" ] && TRANSCRIPT=""
    [ -n "$TRANSCRIPT" ] && SESSION_ID=$(basename "$TRANSCRIPT" .jsonl)
  fi
fi

# Session depth check (min 3 user turns)
SESSION_DEEP="false"
if [ -n "$TRANSCRIPT" ] && [ -f "$TRANSCRIPT" ]; then
  # Use jq for accurate top-level type matching; grep may over-count when the literal appears in content
  if [ "$_HAS_JQ" = "true" ]; then
    USER_TURNS=$(jq -c 'select(.type == "user")' "$TRANSCRIPT" 2>/dev/null | wc -l | tr -d ' ')
  else
    USER_TURNS=$(grep -c '"type":"user"' "$TRANSCRIPT" 2>/dev/null || echo "0")
  fi
  if [ "$USER_TURNS" -ge 3 ]; then
    SESSION_DEEP="true"
    log "Session depth: $USER_TURNS turns"
    dbg "SESSION_DEEP=true USER_TURNS=$USER_TURNS TRANSCRIPT=$TRANSCRIPT"
  else
    log "Shallow session ($USER_TURNS turns)"
    dbg "SESSION_DEEP=false USER_TURNS=$USER_TURNS"
  fi
else
  log "No transcript found"
  dbg "No transcript found"
fi

mkdir -p "$SIDECAR_DIR"

NOW=$(date +%s)
TODAY=$(date '+%Y-%m-%d')
FILTER_LIB="$SCRIPT_DIR/lib/transcript-filter.cjs"
MARKER_SUFFIX="${SESSION_ID:-$$}"

# --- Feature modules ---
source "$SCRIPT_DIR/eval-helpers"
source "$SCRIPT_DIR/eval-reinforce"
source "$SCRIPT_DIR/eval-learning"
source "$SCRIPT_DIR/eval-decisions"
source "$SCRIPT_DIR/eval-knowledge"

dbg "=== HOOK COMPLETE ==="
exit 0
