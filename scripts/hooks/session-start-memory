#!/bin/bash

# SessionStart Hook
# Injects working memory as additionalContext.
# Memory: restores .devflow/memory/WORKING-MEMORY.md + git state + compact recovery.

# Safe no-op fallback: must exist before set -e and before hook-bootstrap is sourced.
dbg() { :; }

set -e

# JSON parsing (jq with node fallback) — silently no-op if neither available
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$SCRIPT_DIR/hook-bootstrap" "session-start-memory"

source "$SCRIPT_DIR/json-parse" || { echo "session-start-memory: failed to source json-parse" >&2; exit 1; }
if [ "$_JSON_AVAILABLE" = "false" ]; then exit 0; fi

INPUT=$(cat)

CWD=$(printf '%s' "$INPUT" | json_field "cwd" "")
if [ -z "$CWD" ] || [ ! -d "$CWD" ]; then
  dbg "EXIT: bad CWD"
  exit 0
fi

devflow_debug_set_cwd "$CWD"
dbg "CWD=$CWD"

DEVFLOW_DIR="$CWD/.devflow"
MEMORY_DIR="$DEVFLOW_DIR/memory"
DREAM_DIR="$DEVFLOW_DIR/dream"

# Normal logging
source "$SCRIPT_DIR/hook-log-init" "session-start-memory"

# Check dream config — single source of truth for memory enabled/disabled.
# The legacy .working-memory-disabled sentinel is intentionally NOT checked here:
# dream config supersedes it per ADR-001 (clean break). Users who previously
# disabled via sentinel have it replaced by config.json on first dream init.
DREAM_CONFIG="$DREAM_DIR/config.json"
if [ -f "$DREAM_CONFIG" ]; then
  MEMORY_ENABLED=$(json_field_file "$DREAM_CONFIG" "memory" "true")
  if [ "$MEMORY_ENABLED" = "false" ]; then
    dbg "EXIT: memory disabled in dream config"
    exit 0
  fi
fi

CONTEXT=""

# --- Section 1: Working Memory ---

MEMORY_FILE="$MEMORY_DIR/WORKING-MEMORY.md"

if [ -f "$MEMORY_FILE" ]; then
  dbg "MEMORY_FILE exists: $MEMORY_FILE"
  MEMORY_CONTENT=$(head -c 65536 "$MEMORY_FILE")

  # Compute staleness warning
  source "$SCRIPT_DIR/get-mtime" || { echo "session-start-memory: failed to source get-mtime" >&2; exit 1; }
  FILE_MTIME=$(get_mtime "$MEMORY_FILE")
  NOW=$(date +%s)
  AGE=$(( NOW - FILE_MTIME ))
  dbg "MEMORY_FILE AGE=${AGE}s"

  # Check for pre-compact memory snapshot (compaction recovery)
  BACKUP_FILE="$MEMORY_DIR/backup.json"
  COMPACT_NOTE=""
  if [ -f "$BACKUP_FILE" ]; then
    BACKUP_MEMORY=$(json_field_file "$BACKUP_FILE" "memory_snapshot" "")
    if [ -n "$BACKUP_MEMORY" ]; then
      BACKUP_TS=$(json_field_file "$BACKUP_FILE" "timestamp" "")
      BACKUP_EPOCH=0
      if [ -n "$BACKUP_TS" ]; then
        BACKUP_EPOCH=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$BACKUP_TS" +%s 2>/dev/null \
          || date -d "$BACKUP_TS" +%s 2>/dev/null \
          || echo "0")
      fi
      if [ "$BACKUP_EPOCH" -gt "$FILE_MTIME" ]; then
        dbg "Compact recovery available: BACKUP_TS=$BACKUP_TS"
        COMPACT_NOTE="
--- PRE-COMPACT SNAPSHOT ($BACKUP_TS) ---
Context was compacted. This snapshot may contain decisions or progress not yet in working memory.

$BACKUP_MEMORY
"
      fi
    fi
  fi

  STALE_WARNING=""
  if [ "$AGE" -gt 3600 ]; then
    HOURS=$(( AGE / 3600 ))
    dbg "Memory is stale: AGE=${AGE}s HOURS=${HOURS}"
    STALE_WARNING="⚠ This working memory is ${HOURS}h old. Verify before relying on it.

"
  fi

  # Capture fresh git state
  GIT_BRANCH=""
  GIT_STATUS=""
  GIT_LOG=""

  if cd "$CWD" 2>/dev/null && git rev-parse --git-dir >/dev/null 2>&1; then
    GIT_BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")
    GIT_STATUS=$(git status --porcelain 2>/dev/null | head -20)
    GIT_LOG=$(git log --oneline -5 2>/dev/null || echo "")
    dbg "GIT_BRANCH=$GIT_BRANCH"
  fi

  # Build memory context
  CONTEXT="${STALE_WARNING}--- WORKING MEMORY (from previous session) ---

${MEMORY_CONTENT}"

  CONTEXT="${CONTEXT}

--- CURRENT GIT STATE ---
Branch: ${GIT_BRANCH}
Recent commits:
${GIT_LOG}"

  if [ -n "$GIT_STATUS" ]; then
    CONTEXT="${CONTEXT}
Uncommitted changes:
${GIT_STATUS}"
  fi

  if [ -n "$COMPACT_NOTE" ]; then
    CONTEXT="${CONTEXT}
${COMPACT_NOTE}"
  fi
else
  dbg "MEMORY_FILE not found: $MEMORY_FILE"
fi

# --- Section 2: Unprocessed turns from previous session ---
# If the queue has entries that haven't been summarized into WORKING-MEMORY.md yet,
# inject them as raw context so the assistant starts with full information.

QUEUE_FILE="$MEMORY_DIR/.pending-turns.jsonl"
if [ -f "$QUEUE_FILE" ] && [ -s "$QUEUE_FILE" ]; then
  QUEUE_LINES=$(wc -l < "$QUEUE_FILE" | tr -d ' ')
  dbg "Pending queue: $QUEUE_LINES entries"

  if [ "$QUEUE_LINES" -gt 0 ]; then
    if [ "$_HAS_JQ" = "true" ]; then
      QUEUE_SUMMARY=$(tail -20 "$QUEUE_FILE" | jq -r '"[\(.role)]: \(.content[0:200])"' 2>/dev/null)
    else
      QUEUE_SUMMARY=$(tail -20 "$QUEUE_FILE" | node -e "
        const lines = require('fs').readFileSync('/dev/stdin','utf8').trim().split('\n');
        lines.forEach(l => { try { const o = JSON.parse(l); console.log('[' + o.role + ']: ' + (o.content||'').slice(0,200)); } catch(e) {} });
      " 2>/dev/null)
    fi

    if [ -n "$QUEUE_SUMMARY" ]; then
      TRUNCATION_NOTE=""
      if [ "$QUEUE_LINES" -gt 20 ]; then
        TRUNCATION_NOTE="(showing last 20 of $QUEUE_LINES entries)
"
      fi

      CONTEXT="${CONTEXT}

--- UNPROCESSED TURNS (not yet in working memory) ---
${TRUNCATION_NOTE}${QUEUE_SUMMARY}"
      dbg "Injected $QUEUE_LINES pending queue entries"
    fi
  fi
fi

# --- Output ---

# Only output if we have something to inject
if [ -z "$CONTEXT" ]; then
  dbg "EXIT: no context to inject"
  exit 0
fi

dbg "OUTPUT_LENGTH=${#CONTEXT}"
log "Injecting memory context (${#CONTEXT} chars)"
dbg "=== HOOK COMPLETE ==="

# Output as additionalContext JSON envelope (Claude sees it as system context, not user-visible)
json_session_output "$CONTEXT"
