#!/bin/bash
# sidecar-evaluate: Artifact reinforcement module.
# Updates last_seen for self-learning artifacts loaded during this session.
# Source from sidecar-evaluate orchestrator after eval-helpers.
#
# Requires (from orchestrator namespace):
#   LEARNING_ENABLED, TRANSCRIPT, SIDECAR_DIR, LEARNING_DIR,
#   _HAS_JQ, log(), dbg(), sidecar_lock_acquire(), sidecar_lock_release(),
#   _eval_release_lock()

: "${SIDECAR_DIR:?eval-reinforce: SIDECAR_DIR must be set by orchestrator}"
: "${LEARNING_DIR:?eval-reinforce: LEARNING_DIR must be set by orchestrator}"
: "${_HAS_JQ:?eval-reinforce: _HAS_JQ must be set by orchestrator}"

# _reinforce_via_jq LOG NOW_ISO SLUGS_PATTERN TEMP_LOG — update last_seen via jq; returns 0 if changed
_reinforce_via_jq() {
  local log_file="$1" now_iso="$2" slugs_pattern="$3" temp_log="$4"
  if jq -c --arg now "$now_iso" --arg slugs "$slugs_pattern" '
    def extract_slug:
      .artifact_path as $p |
      if ($p | contains("/commands/")) then ($p | split("/") | last | rtrimstr(".md"))
      else ($p | split("/") | .[-2])
      end;
    if .status == "created" and .artifact_path != null and .artifact_path != "" then
      extract_slug as $slug |
      if ($slugs | split("|") | any(. == $slug)) then .last_seen = $now
      else .
      end
    else .
    end
  ' "$log_file" > "$temp_log" 2>/dev/null; then
    if ! cmp -s "$log_file" "$temp_log"; then
      mv "$temp_log" "$log_file"
      return 0
    fi
    rm -f "$temp_log"
  else
    rm -f "$temp_log"
  fi
  return 1
}

# _reinforce_via_node LOG NOW_ISO SLUGS_PATTERN — update last_seen via readline streaming; echoes 'true'/'false'
_reinforce_via_node() {
  local log_file="$1" now_iso="$2" slugs_pattern="$3"
  node -e "
    const readline=require('readline');
    const fs=require('fs');
    const logPath=process.argv[1];
    const slugs=process.argv[2].split('|');
    const now=process.argv[3];
    const tmpPath=logPath+'.tmp.'+process.pid;
    const rl=readline.createInterface({input:fs.createReadStream(logPath),crlfDelay:Infinity});
    const result=[];
    let reinforced=false;
    rl.on('line',line=>{
      if(!line.trim())return;
      try{
        const obj=JSON.parse(line);
        if(obj.status==='created'&&obj.artifact_path){
          const slug=obj.artifact_path.includes('/commands/')
            ?obj.artifact_path.split('/').pop().replace(/\.md$/,'')
            :obj.artifact_path.split('/').slice(-2,-1)[0];
          if(slugs.includes(slug)){obj.last_seen=now;reinforced=true;}
        }
        result.push(JSON.stringify(obj));
      }catch(e){result.push(line);}
    });
    rl.on('close',()=>{
      if(reinforced){
        fs.writeFileSync(tmpPath,result.join('\n')+'\n');
        fs.renameSync(tmpPath,logPath);
      }
      process.stdout.write(reinforced?'true':'false');
    });
  " -- "$log_file" "$slugs_pattern" "$now_iso" 2>/dev/null || echo "false"
}

if [ "$LEARNING_ENABLED" = "true" ] && [ -n "$TRANSCRIPT" ] && [ -f "$TRANSCRIPT" ]; then
  _REINF_LEARNING_LOG="$LEARNING_DIR/learning-log.jsonl"
  if [ -f "$_REINF_LEARNING_LOG" ]; then
    # Extract slugs of self-learning artifacts used in this session
    _REINF_LOADED_SLUGS=$(grep -oE 'self-learning[:/][a-z0-9-]+' "$TRANSCRIPT" 2>/dev/null | \
      sed 's|self-learning[:/]||' | sort -u || true)
    if [ -n "$_REINF_LOADED_SLUGS" ]; then
      _REINF_NOW_ISO=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
      _REINF_SLUGS_PATTERN=$(echo "$_REINF_LOADED_SLUGS" | paste -sd '|' -)
      if sidecar_lock_acquire "$SIDECAR_DIR/.reinforce.lock" 3; then
        trap '_eval_release_lock "$SIDECAR_DIR/.reinforce.lock"' EXIT
        _REINF_TEMP_LOG="${_REINF_LEARNING_LOG}.tmp.$$"
        rm -f "$_REINF_TEMP_LOG" 2>/dev/null || true
        if [ "$_HAS_JQ" = "true" ]; then
          if _reinforce_via_jq "$_REINF_LEARNING_LOG" "$_REINF_NOW_ISO" "$_REINF_SLUGS_PATTERN" "$_REINF_TEMP_LOG"; then
            log "Reinforced artifacts for slugs: $_REINF_SLUGS_PATTERN"
          fi
        else
          _REINF_RESULT=$(_reinforce_via_node "$_REINF_LEARNING_LOG" "$_REINF_NOW_ISO" "$_REINF_SLUGS_PATTERN")
          if [ "$_REINF_RESULT" = "true" ]; then
            log "Reinforced artifacts for slugs: $_REINF_SLUGS_PATTERN (node)"
          fi
        fi
        sidecar_lock_release "$SIDECAR_DIR/.reinforce.lock"
        trap - EXIT
      else
        log "Reinforcement skipped: could not acquire lock"
      fi
    fi
  fi
fi
