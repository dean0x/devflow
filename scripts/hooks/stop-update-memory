#!/bin/bash

# Working Memory: Stop Hook
# Captures assistant responses to .memory/.pending-turns.jsonl queue,
# then spawns background updater (throttled) to process accumulated turns.
# On failure: does nothing (stale memory is better than fake data).

set -e

# Break feedback loop: background updater's headless session triggers stop hook on exit.
if [ "${DEVFLOW_BG_UPDATER:-}" = "1" ]; then exit 0; fi

# Resolve script directory once
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# JSON parsing (jq with node fallback)
source "$SCRIPT_DIR/json-parse" || { echo "stop-update-memory: failed to source json-parse" >&2; exit 1; }
if [ "$_JSON_AVAILABLE" = "false" ]; then exit 0; fi

INPUT=$(cat)

# Resolve project directory, stop reason, and response text in one subprocess.
# Uses ASCII SOH (0x01) as delimiter for bash 3.2 compatibility with cut.
if [ "$_HAS_JQ" = "true" ]; then
  _FIELDS=$(printf '%s' "$INPUT" | jq -r '(.cwd // "") + "\u0001" + (.stop_reason // "") + "\u0001" + (.response_text // "")')
else
  _FIELDS=$(printf '%s' "$INPUT" | node -e "
    const j=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
    process.stdout.write((j.cwd||'')+'\x01'+(j.stop_reason||'')+'\x01'+(j.response_text||''))")
fi
CWD=$(printf '%s' "$_FIELDS" | cut -d$'\001' -f1)
STOP_REASON=$(printf '%s' "$_FIELDS" | cut -d$'\001' -f2)
RESPONSE_TEXT=$(printf '%s' "$_FIELDS" | cut -d$'\001' -f3-)

if [ -z "$CWD" ] || [ ! -d "$CWD" ]; then exit 0; fi

# Auto-create .memory/ and ensure .gitignore entries
source "$SCRIPT_DIR/ensure-memory-gitignore" "$CWD" || exit 0

[ -f "$CWD/.memory/.working-memory-disabled" ] && exit 0

source "$SCRIPT_DIR/get-mtime" || { echo "stop-update-memory: failed to source get-mtime" >&2; exit 1; }

# Logging
source "$SCRIPT_DIR/log-paths" || { echo "stop-update-memory: failed to source log-paths" >&2; exit 1; }
LOG_FILE="$(devflow_log_dir "$CWD")/.working-memory-update.log"
log() { echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [stop-hook] $1" >> "$LOG_FILE"; }

# --- Filter: only capture end_turn stops ---
if [ "$STOP_REASON" != "end_turn" ]; then
  exit 0
fi

# --- Auto-clean orphan user-only queues ---
QUEUE_FILE="$CWD/.memory/.pending-turns.jsonl"
if [ -f "$QUEUE_FILE" ]; then
  if ! grep -qF '"role":"assistant"' "$QUEUE_FILE" 2>/dev/null; then
    log "Auto-clean: truncating orphan user-only queue ($(wc -l < "$QUEUE_FILE" | tr -d ' ') lines)"
    : > "$QUEUE_FILE"
  fi
fi

# Skip if empty
if [ -z "$RESPONSE_TEXT" ]; then
  log "Skipped: empty response_text"
  exit 0
fi

# Truncate to 2000 chars
if [ ${#RESPONSE_TEXT} -gt 2000 ]; then
  RESPONSE_TEXT="${RESPONSE_TEXT:0:2000}... [truncated]"
fi

# --- Append to queue ---
# Ensure queue file has restricted permissions (600) if not yet created.
# umask 077 ensures the file is never world-readable, even momentarily (avoids TOCTOU).
if [ ! -f "$QUEUE_FILE" ]; then
  (umask 077 && touch "$QUEUE_FILE") 2>/dev/null || true
fi
TS=$(date +%s)
if [ "$_HAS_JQ" = "true" ]; then
  jq -n -c --arg role "assistant" --arg content "$RESPONSE_TEXT" --argjson ts "$TS" \
    '{role: $role, content: $content, ts: $ts}' >> "$QUEUE_FILE"
else
  node -e "process.stdout.write(JSON.stringify({role:'assistant',content:process.argv[1],ts:parseInt(process.argv[2])})+'\n')" \
    -- "$RESPONSE_TEXT" "$TS" >> "$QUEUE_FILE"
fi

# Queue overflow safety: if >200 lines, keep last 100
# NOTE: same 200/100 threshold in background-memory-update
if [ -f "$QUEUE_FILE" ]; then
  LINE_COUNT=$(wc -l < "$QUEUE_FILE" | tr -d ' ')
  if [ "$LINE_COUNT" -gt 200 ]; then
    tail -100 "$QUEUE_FILE" > "$QUEUE_FILE.tmp" && mv "$QUEUE_FILE.tmp" "$QUEUE_FILE"
    log "Queue overflow: truncated from $LINE_COUNT to 100 lines"
  fi
fi

log "Captured assistant turn (${#RESPONSE_TEXT} chars)"

# D29: Usage scanner runs after queue append — memory capture is mission-critical, scanning is supplementary
# Scanner is gated by decisions sentinel: skip if decisions feature is disabled
SCANNER="$SCRIPT_DIR/decisions-usage-scan.cjs"
if [ -f "$SCANNER" ] && [ ! -f "$CWD/.memory/decisions/.disabled" ]; then
  printf '%s' "$RESPONSE_TEXT" | node "$SCANNER" --cwd "$CWD" 2>/dev/null || true
fi

# --- Throttle: only spawn background updater every 2 minutes ---
TRIGGER_MARKER="$CWD/.memory/.working-memory-last-trigger"
if [ -f "$TRIGGER_MARKER" ]; then
  MARKER_MTIME=$(get_mtime "$TRIGGER_MARKER")
  NOW=$(date +%s)
  AGE=$(( NOW - MARKER_MTIME ))
  if [ "$AGE" -lt 120 ]; then
    log "Throttled: triggered ${AGE}s ago (capture saved, processing deferred)"
    exit 0
  fi
fi

# Resolve claude binary
CLAUDE_BIN=$(command -v claude 2>/dev/null || true)
if [ -z "$CLAUDE_BIN" ]; then
  log "Skipped spawn: claude binary not found"
  exit 0
fi

# Resolve updater script
UPDATER="$SCRIPT_DIR/background-memory-update"
if [ ! -x "$UPDATER" ]; then
  log "Skipped spawn: updater not found/not executable at $UPDATER"
  exit 0
fi

# Touch marker BEFORE spawning (prevents race with concurrent hooks)
touch "$TRIGGER_MARKER"

# Spawn background updater — 2 args (down from 4)
nohup "$UPDATER" "$CWD" "$CLAUDE_BIN" \
  </dev/null >/dev/null 2>&1 &
disown

log "Spawned background updater: cwd=$CWD claude=$CLAUDE_BIN"

exit 0
