{
  "statusLine": {
    "type": "command",
    "command": "${DEVFLOW_DIR}/scripts/hud.sh"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${DEVFLOW_DIR}/scripts/hooks/run-hook capture-turn",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${DEVFLOW_DIR}/scripts/hooks/run-hook memory-worker",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${DEVFLOW_DIR}/scripts/hooks/run-hook session-start-memory",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${DEVFLOW_DIR}/scripts/hooks/run-hook session-start-context",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${DEVFLOW_DIR}/scripts/hooks/run-hook spawn-dream-worker",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${DEVFLOW_DIR}/scripts/hooks/run-hook pre-compact-memory",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "devflow": {
      "source": {
        "source": "github",
        "repo": "dean0x/devflow"
      }
    }
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
